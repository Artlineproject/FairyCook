; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Farming Tale"
run/main_scene="res://Scènes/Zones/Tilemap_Zone_1.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://Script/Globaux/EventBus.gd"
SaveManager="*res://Script/Globaux/SaveManager.gd"
FadeOverlay="*res://Scènes/UI/fade_overlay.tscn"
SceneLoader="*res://Script/Globaux/SceneLoader.gd"
ItemDataBase="*res://Script/DataBase/ItemDataBase.gd"
RecipeDatabase="*res://Script/DataBase/RecipeDatabase.gd"
BuildingDatabase="*res://Script/DataBase/BuildingDatabase.gd"
GameClock="*res://Script/Globaux/GameClock.gd"
InventoryManager="*res://Scènes/Player/InventoryManager.tscn"
EconomyManager="*res://Script/Globaux/EconomyManager.gd"
SalesManager="*res://Script/Globaux/SalesManager.gd"
DayPlanManager="*res://Script/Globaux/DayPlanManager.gd"
DragDropManager="*res://Script/Globaux/DragDropManager.gd"
ToolManager="*res://Script/Globaux/ToolManager.gd"
Player="*res://Scènes/Player/player.tscn"

[display]

window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[file_customization]

folder_colors={
"res://Assets/": "pink",
"res://Ressources/": "yellow",
"res://Script/": "green",
"res://Scènes/": "red"
}

[global_group]

navigation_polygon_source_geometry_group=""

